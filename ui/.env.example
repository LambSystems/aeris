VITE_AERIS_API_BASE=http://localhost:8000

# browser-only = force /models/yolo/best.onnx and show errors
# browser = try /models/yolo/best.onnx first, then fall back to backend
# backend = force FastAPI /scan-frame
# streamlit-embed = render Streamlit YOLO inside the React camera area
VITE_VISION_PROVIDER=streamlit-embed
VITE_STREAMLIT_URL=http://localhost:8501?embed=true
